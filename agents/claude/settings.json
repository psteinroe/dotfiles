{
    "fileSuggestion": {
        "type": "command",
        "command": "~/.claude/file-suggestion.sh"
    },
    "enabledPlugins": {},
    "alwaysThinkingEnabled": true,
    "addCoAuthoredBy": false,
    "autoAcceptEdits": true,
    "enableExtendedThinking": true,
    "statusLineFormat": "${directoryName} ${gitBranch}",
    "environmentVariables": {
        "BASH_COMMAND_TIMEOUT_SECONDS": "300"
    },
    "hooks": {
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/caffeinate.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/caffeinate.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Notification": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "~/.claude/hooks/caffeinate.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PermissionRequest": [
            {
                "matcher": "ExitPlanMode",
                "hooks": [
                    {
                        "type": "command",
                        "command": "plannotator",
                        "timeout": 345600
                    }
                ]
            }
        ]
    }
}
