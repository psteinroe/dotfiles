# Quick PR: commits "initial", pushes, creates PR with AI-generated title/body
# Usage: gpr [-a] [-n] [-e] [-f <issue>]
#   gpr             = commit (if changes) + push + create PR
#   gpr -a          = git add -A first
#   gpr -n          = new random branch first
#   gpr -e          = edit title/body in $EDITOR before creating PR
#   gpr -f <issue>  = add "Fixes <issue>" to PR body
# Env:
#   GPR_PI_MODEL              = Pi model (default: openai-codex/gpt-5.4)
#   GPR_PI_THINKING           = Pi thinking level (default: low)
#   GPR_AI_TIMEOUT_SECONDS    = generation timeout (default: 60)
local ai_timeout="${GPR_AI_TIMEOUT_SECONDS:-60}"
local pi_model="${GPR_PI_MODEL:-openai-codex/gpt-5.4}"
local pi_thinking="${GPR_PI_THINKING:-low}"
local add_all=false new_branch=false edit=false fixes=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -a) add_all=true; shift ;;
    -n) new_branch=true; shift ;;
    -e|--edit) edit=true; shift ;;
    -f|--fixes) fixes="$2"; shift 2 ;;
    *) shift ;;
  esac
done

local repo_root
repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  echo "Not in a git repository."
  return 1
}

$add_all && git -C "$repo_root" add -A :/

local main=$(gh repo view --json defaultBranchRef -q '.defaultBranchRef.name' 2>/dev/null || echo "main")

if $new_branch; then
  local adj=(quick bright calm cool dark fast free gold green happy keen loud mint neat pale pink pure red safe slim soft warm wild)
  local noun=(ant bear bird bolt cave crow dawn deer dove duck fern fish frog hawk iris jade lake leaf lion lynx moon moth oak owl pine pond rain rock rose sage snow star swan tide tree vine wave wolf)
  local branch="${adj[$RANDOM % ${#adj[@]} + 1]}-${noun[$RANDOM % ${#noun[@]} + 1]}"
  git checkout "$main" && git pull && git checkout -b "$branch"
fi

if [ -n "$(git status --porcelain)" ]; then
  if git diff --cached --quiet; then
    echo "Working tree has unstaged changes. Stage them or run gpr -a."
    return 1
  fi
  git commit -m "initial" || return 1
fi

local branch=$(git branch --show-current)
git push -u origin "$branch" || return 1

echo "Collecting changes..."
git fetch origin "$main" --quiet
local log=$(git log "origin/$main"..HEAD --oneline 2>/dev/null)
local diff=$(git diff "origin/$main"...HEAD 2>/dev/null | head -2000)

local prompt='Generate a GitHub PR title and body from these changes.
Title: use conventional commits (feat:, fix:, chore:, docs:, refactor:), under 70 chars.
Body: 2-4 concise bullet points summarizing the changes.
Output EXACTLY this format, no fences, no extra text:
TITLE: <title here>
BODY:
- <bullet>
- <bullet>'

echo "Generating title and description with Pi (${pi_model}, thinking=${pi_thinking})..."
local ai_prompt_file
ai_prompt_file=$(mktemp)
printf "%s\n\nCommits:\n%s\n\nDiff:\n%s" "$prompt" "$log" "$diff" > "$ai_prompt_file"

local ai_output
ai_output=$(perl -e 'alarm shift; exec @ARGV' "$ai_timeout" pi --no-session --no-tools --model "$pi_model" --thinking "$pi_thinking" -p "@$ai_prompt_file" 2>/dev/null)
local ai_exit=$?
rm -f "$ai_prompt_file"

local title=$(echo "$ai_output" | sed -n 's/^TITLE: //p' | head -1)
local body=$(echo "$ai_output" | sed -n '/^BODY:/,$ { /^BODY:/d; p; }')

[[ -n "$fixes" ]] && body="${body}"$'\n\n'"Fixes ${fixes}"

if [[ -z "$title" ]]; then
  if [[ $ai_exit -eq 142 ]]; then
    echo "Pi timed out after ${ai_timeout}s."
  else
    echo "Pi generation failed (exit ${ai_exit})."
  fi
  echo "Falling back to editor."
  gh pr create -e
  return
fi

echo "\n  \033[1m$title\033[0m\n$body\n"

if $edit; then
  local tmpfile=$(mktemp)
  printf '%s\n\n%s' "$title" "$body" > "$tmpfile"
  ${EDITOR:-vim} "$tmpfile"
  title=$(head -1 "$tmpfile")
  body=$(tail -n +3 "$tmpfile")
  rm -f "$tmpfile"
  echo "Creating PR..."
  gh pr create --title "$title" --body "$body"
else
  echo "Creating PR..."
  gh pr create --title "$title" --body "$body"
fi
