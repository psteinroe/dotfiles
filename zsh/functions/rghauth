# Compatibility wrapper. Prefer: rauth [--host host] gh[:github-host]
# Usage: rghauth [host] [github-host]
if [[ $# -gt 2 ]]; then
  echo "Usage: rghauth [host] [github-host]" >&2
  return 1
fi

local host="${RDEV_HOST:-rdev}"
local gh_host="github.com"
if [[ $# -gt 0 ]]; then
  host="$1"
fi
if [[ $# -gt 1 ]]; then
  gh_host="$2"
fi

autoload -Uz rauth
rauth --host "$host" "gh:$gh_host"
