# Upsert a worktree in the current repo and attach/create a tmux session for it.
# Usage: wttmux <worktree|branch|pr-number>
if [[ $# -lt 1 ]]; then
  echo "Usage: wttmux <worktree|branch|pr-number>" >&2
  return 1
fi

local dotfiles="${RDEV_DOTFILES:-$HOME/Developer/dotfiles}"
unset WTENSURE_PRINT_PATH
source "$dotfiles/zsh/functions/wtensure" "$1" || return

if ! infocmp "${TERM:-}" >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

if [[ -n "$TMUX" ]]; then
  tmux has-session -t "$WTENSURE_SESSION" 2>/dev/null || tmux new-session -d -s "$WTENSURE_SESSION" -c "$WTENSURE_WORKTREE_PATH"
  tmux switch-client -t "$WTENSURE_SESSION"
else
  tmux new-session -A -s "$WTENSURE_SESSION" -c "$WTENSURE_WORKTREE_PATH"
fi
