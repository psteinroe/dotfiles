# Clean orphaned tmux sessions for the current repo's worktrees.
# Usage: wttmuxclean [--force]
#
# Finds tmux sessions whose names match the current repo's wttmux/wtensure
# prefix and whose recorded tmux session_path no longer exists. By default this
# prompts before killing; --force kills without prompting.
if [[ $# -gt 1 || ( $# -eq 1 && "$1" != "--force" && "$1" != "-f" ) ]]; then
  echo "Usage: wttmuxclean [--force]" >&2
  return 1
fi

local force=0
if [[ "${1:-}" == "--force" || "${1:-}" == "-f" ]]; then
  force=1
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "wttmuxclean must be run inside a git repository/worktree" >&2
  return 1
fi

local dotfiles="${RDEV_DOTFILES:-$HOME/Developer/dotfiles}"
source "$dotfiles/zsh/functions/_wt_tmux_helpers" || return

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux not available."
  return 0
fi

local repo_root="$(_wt_main_repo_root)"
if [[ -z "$repo_root" ]]; then
  echo "Not in a git worktree repository" >&2
  return 1
fi

local orphan_file
orphan_file=$(mktemp)
_wt_collect_orphaned_tmux_sessions "$repo_root" "$orphan_file"

if [[ ! -s "$orphan_file" ]]; then
  echo "No orphaned tmux sessions found for this repo."
  rm -f "$orphan_file"
  return 0
fi

echo "\nOrphaned tmux sessions for $(_wt_repo_name_from_root "$repo_root") whose session_path is missing:"
while IFS=$'\t' read -r session_name session_path session_attached; do
  [[ -n "$session_path" ]] || session_path="(empty)"
  echo "  $session_name  path=$session_path  attached=$session_attached"
done < "$orphan_file"

if (( ! force )); then
  echo -n "\nKill these sessions? (y/N): "
  local response
  read response
  if [[ ! "$response" =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    rm -f "$orphan_file"
    return 0
  fi
fi

while IFS=$'\t' read -r session_name _session_path _session_attached; do
  _wt_kill_tmux_session_name "$session_name"
done < "$orphan_file"

rm -f "$orphan_file"
echo "\nDone."
