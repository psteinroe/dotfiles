# Upsert a worktree in the current repo and cd into it, without attaching tmux.
# Usage: wtensure <worktree|branch|pr-number>
#
# Outputs:
#   Sets WTENSURE_REPO_NAME, WTENSURE_WORKTREE_NAME, WTENSURE_WORKTREE_PATH,
#   and WTENSURE_SESSION in the caller when sourced.
#
# Set WTENSURE_PRINT_PATH=1 to print the resolved worktree path as the final
# stdout line. This is useful for wrappers that need to launch another tool in
# the resolved remote cwd.
if [[ $# -lt 1 ]]; then
  echo "Usage: wtensure <worktree|branch|pr-number>" >&2
  return 1
fi

# Be robust when launched from mobile SSH/sudo shells that do not source the
# normal Home Manager PATH. `tmux` may live in /usr/bin or the Nix profile.
export PATH="$HOME/.local/bin:$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

local input="$1"
local worktree_name="$input"
local input_is_pr=0

if [[ "$input" =~ ^[0-9]+$ ]]; then
  input_is_pr=1
  worktree_name="pr-$input"
else
  worktree_name="${input//\//-}"
fi

local repo_root
repo_root=$(git worktree list --porcelain 2>/dev/null | awk '/^worktree / { print substr($0, 10); exit }')
if [[ -z "$repo_root" ]]; then
  echo "Not in a git worktree repository" >&2
  return 1
fi

local repo_base="$(basename "$repo_root")"
local repo_parent="$(dirname "$repo_root")"
local repo_name="$repo_base"
local worktree_root
local worktree_path
local existing_worktree_path=""

if [[ "$repo_base" == *.git ]]; then
  repo_name="${repo_base%.git}"
  worktree_root="$repo_parent/$repo_base"
else
  worktree_root="$repo_parent/$repo_base.git"
fi

worktree_path="$worktree_root/$worktree_name"

# Prefer an already-registered worktree at the exact path the caller supplied.
# This preserves older/manual worktrees created with slashy branch names as
# nested directories (for example repo.git/fix/journey-templates), while new
# branch upserts continue to use the normalized repo.git/fix-journey-templates
# path. Numeric inputs keep their existing PR-number meaning unless an absolute
# worktree path is supplied.
if [[ "$input" == /* ]]; then
  existing_worktree_path="$input"
elif (( input_is_pr == 0 )); then
  existing_worktree_path="$worktree_root/$input"
fi

if [[ -n "$existing_worktree_path" ]] && git worktree list --porcelain 2>/dev/null | awk -v path="$existing_worktree_path" '/^worktree / { if (substr($0, 10) == path) found = 1 } END { exit found ? 0 : 1 }'; then
  worktree_path="$existing_worktree_path"
  worktree_name="${existing_worktree_path#$worktree_root/}"
  if [[ "$worktree_name" == "$existing_worktree_path" ]]; then
    worktree_name="$(basename "$existing_worktree_path")"
  fi
fi

local dotfiles="${RDEV_DOTFILES:-$HOME/Developer/dotfiles}"
wtsetup() { source "$dotfiles/zsh/functions/wtsetup" "$@"; }
wtcheckout() { source "$dotfiles/zsh/functions/wtcheckout" "$@"; }

wtensure_pull_origin_if_clean() {
  local branch="$1"
  local git_status
  local counts ahead behind

  git_status=$(git status --porcelain) || return
  if [[ -n "$git_status" ]]; then
    echo "Local changes present in $PWD; skipping pull from origin/$branch." >&2
    return 0
  fi

  counts=$(git rev-list --left-right --count "HEAD...origin/$branch") || return
  ahead="${counts%%[[:space:]]*}"
  behind="${counts##*[[:space:]]}"

  if (( ahead == 0 && behind == 0 )); then
    return 0
  elif (( ahead == 0 )); then
    git merge --ff-only "origin/$branch"
  elif (( behind == 0 )); then
    echo "Local $branch is $ahead commit(s) ahead of origin/$branch; leaving it as-is." >&2
    return 0
  elif [[ "${WTENSURE_AUTO_REBASE:-1}" == 0 ]]; then
    echo "Local $branch and origin/$branch have diverged ($ahead local, $behind remote commit(s)); set WTENSURE_AUTO_REBASE=1 or run: git rebase origin/$branch" >&2
    return 1
  else
    echo "Local $branch and origin/$branch have diverged ($ahead local, $behind remote commit(s)); rebasing clean local commits onto origin/$branch..." >&2
    git rebase "origin/$branch" || {
      local rebase_status=$?
      echo "Automatic rebase failed in $PWD. Resolve conflicts with git rebase --continue, or abort with git rebase --abort." >&2
      return $rebase_status
    }
  fi
}

# Always fetch first so a just-pushed local branch is visible before deciding
# whether this is an existing remote branch or a new branch to create.
git fetch origin --prune || return

if [[ ! -d "$worktree_path" ]]; then
  if [[ "$input" =~ ^[0-9]+$ ]]; then
    wtcheckout "$input" || return
  elif git show-ref --verify --quiet "refs/remotes/origin/$input"; then
    if git show-ref --verify --quiet "refs/heads/$input"; then
      git branch --set-upstream-to="origin/$input" "$input" >/dev/null 2>&1 || true
      git worktree add "$worktree_path" "$input" || return
    else
      git worktree add --track -b "$input" "$worktree_path" "origin/$input" || return
    fi
    cd "$worktree_path" || return
    wtensure_pull_origin_if_clean "$input" || return
    wtsetup
  elif git show-ref --verify --quiet "refs/heads/$input"; then
    git worktree add "$worktree_path" "$input" || return
    cd "$worktree_path" || return
    wtsetup
  else
    local base
    base=$(source "$dotfiles/zsh/functions/gh-default-branch") || return
    git worktree add "$worktree_path" -b "$input" --no-track "origin/$base" || return
    cd "$worktree_path" || return
    wtsetup
  fi
else
  cd "$worktree_path" || return
fi

if [[ ! "$input" =~ ^[0-9]+$ ]] && git show-ref --verify --quiet "refs/remotes/origin/$input" && [[ "$(git branch --show-current 2>/dev/null)" == "$input" ]]; then
  git branch --set-upstream-to="origin/$input" "$input" >/dev/null 2>&1 || true
  wtensure_pull_origin_if_clean "$input" || return
fi

typeset -g WTENSURE_REPO_NAME="$repo_name"
typeset -g WTENSURE_WORKTREE_NAME="$worktree_name"
typeset -g WTENSURE_WORKTREE_PATH="$PWD"
typeset -g WTENSURE_SESSION="${repo_name}-${worktree_name}"
WTENSURE_SESSION="${WTENSURE_SESSION//\//-}"
WTENSURE_SESSION="${WTENSURE_SESSION//[^A-Za-z0-9_.-]/-}"

if [[ "${WTENSURE_PRINT_PATH:-}" == 1 ]]; then
  print -r -- "$WTENSURE_WORKTREE_PATH"
fi
