# Attach/create a persistent remote tmux session for a repo worktree.
# Upserts the worktree: if it does not exist, create it with wtcheckout first.
# Usage: rdev <repo> <worktree|branch|pr-number>
if [[ $# -lt 2 ]]; then
  echo "Usage: rdev <repo> <worktree|branch|pr-number>" >&2
  return 1
fi

rdev-host "${RDEV_HOST:-rdev}" "$@"
