# From Mac: upsert a worktree on the remote VM and attach/create its remote tmux session.
# Usage: rdev <repo> <worktree|branch|pr-number>
# Example: rdev hellomateo dev
if [[ $# -lt 2 ]]; then
  echo "Usage: rdev <repo> <worktree|branch|pr-number>" >&2
  return 1
fi

rdev-host "${RDEV_HOST:-rdev}" "$@"
