# Print the Herdr binary this dotfiles setup should use.
_herdr_binary() {
  local candidate
  local -a candidates

  if [[ "$OSTYPE" == darwin* ]]; then
    candidates=(
      "${HERDR_BIN:-}"
      "/etc/profiles/per-user/$USER/bin/herdr"
      "$HOME/.nix-profile/bin/herdr"
      herdr
    )
  else
    candidates=(
      "${HERDR_BIN:-}"
      "$HOME/.local/state/nix/profiles/home-manager/home-path/bin/herdr"
      "$HOME/.nix-profile/bin/herdr"
      "/etc/profiles/per-user/$USER/bin/herdr"
      herdr
    )
  fi

  for candidate in "${candidates[@]}"
  do
    [[ -n "$candidate" ]] || continue
    if [[ "$candidate" == */* ]]; then
      [[ -x "$candidate" ]] || continue
      print -r -- "$candidate"
      return 0
    fi
    command -v "$candidate"
    return $?
  done

  echo "herdr is not on PATH" >&2
  return 1
}
