# Git worktree helper - lists worktrees and cleans up merged PRs
git worktree list

if ! command -v gh >/dev/null 2>&1; then
  echo "\nGitHub CLI (gh) required for safe cleanup."
  return 1
fi

echo "\nChecking PR status..."
local repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
local temp_file=$(mktemp)
local wt_file=$(mktemp)
local status_dir=$(mktemp -d)

local dotfiles="${RDEV_DOTFILES:-$HOME/Developer/dotfiles}"
source "$dotfiles/zsh/functions/_wt_tmux_helpers" 2>/dev/null || true
source "$dotfiles/zsh/functions/_herdr_worktree_helpers" 2>/dev/null || true
local session_repo_root=""
if (( $+functions[_wt_main_repo_root] )); then
  session_repo_root=$(_wt_main_repo_root)
fi
local herdr_repo_name=""
if (( $+functions[_h_repo_context] )); then
  _h_repo_context >/dev/null 2>&1 && herdr_repo_name="${H_REPO_NAME:-}"
fi

local default_branch=$(gh repo view --json defaultBranchRef -q '.defaultBranchRef.name' 2>/dev/null)
if [ -z "$default_branch" ]; then
  default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')
fi
[ -n "$default_branch" ] || default_branch="main"

local protected_branches=("$default_branch" main master trunk)

is_protected_branch() {
  local branch="$1"
  local protected
  for protected in "${protected_branches[@]}"; do
    if [ "$branch" = "$protected" ]; then
      return 0
    fi
  done
  return 1
}

# Collect worktrees (avoid piped while-read subshell)
git worktree list --porcelain | grep '^worktree' | cut -d' ' -f2- > "$wt_file"

local worktrees=()
while read worktree_path; do
  if [ "$worktree_path" != "$repo_root" ] && [ "$worktree_path" != "$(dirname "$repo_root")/$(basename "$repo_root")" ]; then
    local branch=$(git -C "$worktree_path" branch --show-current 2>/dev/null)
    if [ -n "$branch" ]; then
      if is_protected_branch "$branch"; then
        echo "Protected: $branch"
        continue
      fi
      worktrees+=("$worktree_path:$branch")
    fi
  fi
done < "$wt_file"
rm -f "$wt_file"

# Check PR status in parallel (suppress job control noise)
setopt local_options no_monitor no_notify
local pids=()
local status_files=()
for entry in "${worktrees[@]}"; do
  local branch="${entry#*:}"
  local status_file="$status_dir/$(( ${#status_files[@]} + 1 ))"
  gh pr view "$branch" --json state -q '.state' > "$status_file" 2>/dev/null &
  pids+=($!)
  status_files+=("$status_file")
done
for pid in "${pids[@]}"; do wait "$pid" 2>/dev/null; done

local status_index=1
for entry in "${worktrees[@]}"; do
  local worktree_path="${entry%%:*}"
  local branch="${entry#*:}"
  local pr_state=$(<"${status_files[$status_index]}")
  status_index=$((status_index + 1))
  case "$pr_state" in
    "MERGED") echo "Merged: $branch"; echo "$worktree_path:$branch" >> "$temp_file" ;;
    "CLOSED") echo "Closed: $branch"; echo "$worktree_path:$branch" >> "$temp_file" ;;
    "OPEN") echo "Active: $branch" ;;
    "") echo "No PR: $branch" ;;
  esac
done
rm -rf "$status_dir"

if [ ! -s "$temp_file" ]; then
  echo "\nNo merged/closed PRs found."
  rm -f "$temp_file"
  return 0
fi

echo "\nRemovable worktrees:"
while IFS=: read -r worktree_path branch; do
  echo "  $branch"
done < "$temp_file"

echo -n "\nRemove these? (y/N): "
read response
local cleanup_status=0
if [[ "$response" =~ ^[Yy]$ ]]; then
  # Remove worktrees in parallel, then clean up only the tmux/Herdr workspaces
  # whose Git removals succeeded. Guard protected branches again here so a
  # stale temp file can never remove main/default.
  local remove_pids=()
  local remove_paths=()
  local remove_branches=()
  while IFS=: read -r worktree_path branch; do
    if is_protected_branch "$branch"; then
      echo "Skipping protected branch: $branch"
      continue
    fi
    echo "Removing $branch..."
    git worktree remove --force "$worktree_path" &
    remove_pids+=($!)
    remove_paths+=("$worktree_path")
    remove_branches+=("$branch")
  done < "$temp_file"

  local failed_removals=0
  local successful_indexes=()
  local i
  for (( i = 1; i <= ${#remove_pids[@]}; i++ )); do
    if wait "${remove_pids[$i]}"; then
      successful_indexes+=("$i")
    else
      echo "Failed to remove ${remove_branches[$i]} (${remove_paths[$i]})." >&2
      failed_removals=$((failed_removals + 1))
    fi
  done

  for i in "${successful_indexes[@]}"; do
    worktree_path="${remove_paths[$i]}"
    if (( $+functions[_wt_kill_tmux_for_worktree] )); then
      _wt_kill_tmux_for_worktree "$session_repo_root" "$worktree_path"
    fi
    if (( $+functions[_h_close_workspace_for_path] )); then
      _h_close_workspace_for_path "$worktree_path" "$herdr_repo_name" || true
    fi
  done

  git worktree prune
  if (( $+functions[_h_prune_missing_workspaces] )) && [[ -n "$herdr_repo_name" ]]; then
    HERDR_SESSION="$herdr_repo_name" _h_prune_missing_workspaces || true
  fi

  if (( failed_removals > 0 )); then
    echo "\nCleanup incomplete: $failed_removals worktree(s) could not be removed." >&2
    cleanup_status=1
  else
    echo "\nDone."
  fi
else
  echo "Cancelled."
fi

rm -f "$temp_file"
return "$cleanup_status"
