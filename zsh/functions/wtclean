# Git worktree helper - lists worktrees and cleans up merged PRs
git worktree list

if ! command -v gh >/dev/null 2>&1; then
  echo "\nGitHub CLI (gh) required for safe cleanup."
  return 1
fi

echo "\nChecking PR status..."
local repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
local temp_file=$(mktemp)
local wt_file=$(mktemp)
local status_dir=$(mktemp -d)

# Collect worktrees (avoid piped while-read subshell)
git worktree list --porcelain | grep '^worktree' | cut -d' ' -f2- > "$wt_file"

local worktrees=()
while read worktree_path; do
  if [ "$worktree_path" != "$repo_root" ] && [ "$worktree_path" != "$(dirname "$repo_root")/$(basename "$repo_root")" ]; then
    local branch=$(git -C "$worktree_path" branch --show-current 2>/dev/null)
    if [ -n "$branch" ]; then
      worktrees+=("$worktree_path:$branch")
    fi
  fi
done < "$wt_file"
rm -f "$wt_file"

# Check PR status in parallel (suppress job control noise)
setopt local_options no_monitor no_notify
local pids=()
for entry in "${worktrees[@]}"; do
  local branch="${entry#*:}"
  local safe_name="${branch//\//__}"
  gh pr view "$branch" --json state -q '.state' > "$status_dir/$safe_name" 2>/dev/null &
  pids+=($!)
done
for pid in "${pids[@]}"; do wait "$pid" 2>/dev/null; done

for entry in "${worktrees[@]}"; do
  local worktree_path="${entry%%:*}"
  local branch="${entry#*:}"
  local safe_name="${branch//\//__}"
  local pr_state=$(<"$status_dir/$safe_name")
  case "$pr_state" in
    "MERGED") echo "Merged: $branch"; echo "$worktree_path:$branch" >> "$temp_file" ;;
    "CLOSED") echo "Closed: $branch"; echo "$worktree_path:$branch" >> "$temp_file" ;;
    "OPEN") echo "Active: $branch" ;;
    "") echo "No PR: $branch" ;;
  esac
done
rm -rf "$status_dir"

if [ ! -s "$temp_file" ]; then
  echo "\nNo merged/closed PRs found."
  rm -f "$temp_file"
  return 0
fi

echo "\nRemovable worktrees:"
while IFS=: read -r worktree_path branch; do
  echo "  $branch"
done < "$temp_file"

echo -n "\nRemove these? (y/N): "
read response
if [[ "$response" =~ ^[Yy]$ ]]; then
  # rm directories in parallel, then prune metadata once
  while IFS=: read -r worktree_path branch; do
    echo "Removing $branch..."
    rm -rf "$worktree_path" &
  done < "$temp_file"
  wait
  git worktree prune
  echo "\nDone."
else
  echo "Cancelled."
fi

rm -f "$temp_file"
