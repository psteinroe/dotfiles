# Pick an existing worktree in the current repo and attach/create its tmux session.
# Usage: wttmuxlist
#
# Intended for the remote VM: use this after SSH'ing into a repo when you want
# to choose an existing worktree and jump into its persistent tmux session.
# This does not create new worktrees; use `wttmux <branch|pr>` for upsert.
if [[ $# -gt 0 ]]; then
  echo "Usage: wttmuxlist" >&2
  return 1
fi

# Be robust when launched from mobile SSH/sudo shells that do not source the
# normal Home Manager PATH. `basename` lives in /usr/bin and `tmux` may live in
# either /usr/bin or the Nix profile depending on the machine.
export PATH="$HOME/.local/bin:$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

local repo_root
repo_root=$(git worktree list --porcelain 2>/dev/null | awk '/^worktree / { print substr($0, 10); exit }')
if [[ -z "$repo_root" ]]; then
  echo "Not in a git worktree repository" >&2
  return 1
fi

local repo_base="$(basename "$repo_root")"
local repo_name="$repo_base"
if [[ "$repo_base" == *.git ]]; then
  repo_name="${repo_base%.git}"
fi

local selected
selected=$(git worktree list --porcelain | awk '
  /^worktree / { path = substr($0, 10); branch = "" }
  /^branch / {
    branch = $0
    sub(/^branch refs\/heads\//, "", branch)
    printf "%s\t%s\n", branch, path
  }
  /^detached$/ { printf "%s\t%s\n", "detached", path }
' | fzf --prompt="Worktree tmux> " --height=40% --reverse --with-nth=1,2) || return 0

local selected_path="${selected#*$'\t'}"
if [[ -z "$selected_path" || ! -d "$selected_path" ]]; then
  echo "Cannot attach to selected worktree: $selected_path" >&2
  return 1
fi

local worktree_name="$(basename "$selected_path")"
local session="${repo_name}-${worktree_name}"
session="${session//\//-}"
session="${session//[^A-Za-z0-9_.-]/-}"

if ! infocmp "${TERM:-}" >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

if [[ -n "$TMUX" ]]; then
  tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -s "$session" -c "$selected_path"
  tmux switch-client -t "$session"
else
  tmux new-session -A -s "$session" -c "$selected_path"
fi
