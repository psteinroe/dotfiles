# From Mac: copy local Pi auth to the remote psteinroe user.
# Usage: ragentauth [host] [all|pi[:provider[,provider...]]]
if [[ $# -gt 2 ]]; then
  echo "Usage: ragentauth [host] [all|pi[:provider[,provider...]]]" >&2
  return 1
fi

local host="${RAGENTAUTH_HOST:-rdev}"
local spec="${1:-pi}"
if [[ $# -eq 2 || ( $# -eq 1 && "$1" != all && "$1" != pi && "$1" != pi:* ) ]]; then
  host="$1"
  spec="${2:-pi}"
fi

local local_pi_auth="${PI_AUTH_FILE:-$HOME/.pi/agent/auth.json}"
local default_pi_providers="${RAGENTAUTH_PI_PROVIDERS:-${PI_AUTH_PROVIDERS:-${PI_CODEX_PROVIDER:-openai-codex}}}"
local -a pi_providers
local copy_pi_all=0

case "$spec" in
  all|pi)
    if [[ "$spec" == all ]]; then
      copy_pi_all=1
    else
      pi_providers=(${(@s:,:)default_pi_providers})
    fi
    ;;
  pi:*)
    local providers="${spec#pi:}"
    if [[ "$providers" == all ]]; then
      copy_pi_all=1
    else
      pi_providers=(${(@s:,:)providers})
    fi
    ;;
  *)
    echo "Usage: ragentauth [host] [all|pi[:provider[,provider...]]]" >&2
    return 1
    ;;
esac

if ! command -v jq >/dev/null 2>&1; then
  echo "ragentauth requires jq locally" >&2
  return 1
fi

if [[ ! -f "$local_pi_auth" ]]; then
  echo "Pi auth file not found: $local_pi_auth" >&2
  return 1
fi

local pi_auth
if (( copy_pi_all )); then
  pi_auth=$(jq -c '.' "$local_pi_auth") || return
else
  local jq_filter='with_entries(select(.key as $k | $providers | index($k)))'
  local providers_json
  providers_json=$(printf '%s\n' "${pi_providers[@]}" | jq -R . | jq -s .) || return
  pi_auth=$(jq -c --argjson providers "$providers_json" "$jq_filter" "$local_pi_auth") || return
  if [[ "$(jq 'length' <<<"$pi_auth")" == 0 ]]; then
    echo "No requested Pi providers found in $local_pi_auth: ${pi_providers[*]}" >&2
    return 1
  fi
fi

local payload
payload=$(mktemp) || return
jq -n --argjson piAuth "$pi_auth" '{piAuth: $piAuth}' > "$payload" || {
  rm -f "$payload"
  return 1
}

if ! ssh "$host" 'command -v jq >/dev/null 2>&1'; then
  rm -f "$payload"
  echo "ragentauth requires jq on the remote; run rrebuild/bootstrap first" >&2
  return 1
fi

scp -q "$payload" "$host:/tmp/ragentauth-payload.json" || {
  rm -f "$payload"
  return 1
}
rm -f "$payload"

ssh "$host" 'set -euo pipefail
payload=/tmp/ragentauth-payload.json
trap '\''rm -f "$payload" "$HOME/.pi/agent/auth.json.tmp"'\'' EXIT
mkdir -p "$HOME/.pi/agent"
auth="$HOME/.pi/agent/auth.json"
if [ -f "$auth" ]; then
  jq -s '\''.[0] * .[1].piAuth'\'' "$auth" "$payload" > "$auth.tmp"
else
  jq -c '\''.piAuth'\'' "$payload" > "$auth.tmp"
fi
mv "$auth.tmp" "$auth"
chmod 600 "$auth"
'

local copied=("Pi auth")
if (( ! copy_pi_all )); then
  copied+=("providers: ${pi_providers[*]}")
fi
print -r -- "Copied ${(@j:, :)copied} to $host"
