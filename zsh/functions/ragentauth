# Compatibility wrapper. Prefer: rauth [--host host] pi[:provider[,provider]|all]
# Usage: ragentauth [host] [all|pi[:provider[,provider...]]]
if [[ $# -gt 2 ]]; then
  echo "Usage: ragentauth [host] [all|pi[:provider[,provider...]]]" >&2
  return 1
fi

local host="${RAGENTAUTH_HOST:-${RDEV_HOST:-rdev}}"
local spec="${1:-pi}"
if [[ $# -eq 2 || ( $# -eq 1 && "$1" != all && "$1" != pi && "$1" != pi:* ) ]]; then
  host="$1"
  spec="${2:-pi}"
fi

case "$spec" in
  all) spec="pi:all" ;;
  pi) spec="pi" ;;
  pi:*) ;;
  *)
    echo "Usage: ragentauth [host] [all|pi[:provider[,provider...]]]" >&2
    return 1
    ;;
esac

autoload -Uz rauth
rauth --host "$host" "$spec"
