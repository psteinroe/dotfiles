# List dotfiles helper commands and what they do.
# Usage: devhelp [remote|worktree|auth|all]
local topic="${1:-all}"

if [[ $# -gt 1 ]]; then
  echo "Usage: devhelp [remote|worktree|auth|all]" >&2
  return 1
fi

_case_header() {
  print -P "%F{cyan}$1%f"
}

_case_row() {
  printf '  %-32s %s\n' "$1" "$2"
}

case "$topic" in
  all|remote|worktree|auth) ;;
  *)
    echo "Unknown devhelp topic: $topic" >&2
    echo "Usage: devhelp [remote|worktree|auth|all]" >&2
    return 1
    ;;
esac

if [[ "$topic" == all || "$topic" == remote || "$topic" == worktree ]]; then
  _case_header "Project shortcuts"
  _case_row "hellomateo / rhellomateo" "open local/remote Herdr project session"
  _case_row "dotfiles / rdotfiles" "open local/remote Herdr project session"
  _case_row "sbch / rsbch" "supabase-cache-helpers local/remote session"
  _case_row "pgls / rpgls" "postgres-language-server local/remote session"
  _case_row "pgconductor / rpgconductor" "postgres-conductor local/remote session"
  _case_row "toolshed / rtoolshed" "toolshed local/remote session"
  [[ "$topic" == all ]] && print

  _case_header "Local / remote pairs"
  _case_row "rebuild / rrebuild [host]" "rebuild local or remote Home Manager"
  _case_row "hdev / rdev <repo> [branch|pr]" "open Herdr project session"
  _case_row "wtclean / rwtclean <repo>" "clean merged/closed worktrees"
  _case_row "wtforceclean / rwtforceclean <repo>" "select and force-remove worktrees"
  _case_row "hwtcreate / rhwtcreate" "ensure worktree and focus/open Herdr workspace"
  _case_row "hsyncworktrees / rhsyncworktrees" "sync Git worktrees into Herdr workspaces"
  [[ "$topic" == all ]] && print
fi

if [[ "$topic" == all || "$topic" == worktree ]]; then
  _case_header "Local worktree commands"
  _case_row "wtclone <url> [name]" "bare clone into worktree layout"
  _case_row "wtcreate <branch>" "create a new worktree branch"
  _case_row "wtcheckout <branch|pr>" "checkout an existing branch or PR into a worktree"
  _case_row "wtlist" "list/select existing worktrees"
  _case_row "wtensure <branch|pr>" "upsert worktree and cd into it"
  [[ "$topic" == all ]] && print
fi

if [[ "$topic" == all || "$topic" == remote ]]; then
  _case_header "Remote-only helpers"
  _case_row "ragentauth [host] [spec]" "copy Pi auth to the remote"
  _case_row "rmcpauth [--host h] [all|server...]" "copy Pi MCP OAuth credentials to the remote"
  _case_row "rghauth [host] [github-host]" "copy GitHub CLI auth to the remote"
  _case_row "rssh [dir]" "open a plain remote psteinroe shell"
  _case_row "rpushdev [repo] [msg]" "commit/push current branch, then open it with rdev"
  _case_row "ssh rdev-exe" "recovery path via exe.dev gateway"
  [[ "$topic" == all ]] && print
fi

if [[ "$topic" == all || "$topic" == auth ]]; then
  _case_header "Auth/helper utilities"
  _case_row "gh" "wrap gh to auto-use exe.dev integration hosts from origin"
  _case_row "ragentauth [host] [spec]" "copy Pi auth to the remote"
  _case_row "rmcpauth [--host h] [all|server...]" "copy Pi MCP OAuth credentials to the remote"
  _case_row "rghauth [host] [github-host]" "copy GitHub CLI auth to the remote"
  _case_row "devhelp [topic]" "show this command reference"
fi
