# Copy local Pi OpenAI Codex subscription auth to the remote.
# Usage: rpicodexauth [host]
#
# Copies only the openai-codex entry from ~/.pi/agent/auth.json and merges it
# into the remote ~/.pi/agent/auth.json, preserving other remote credentials.
if [[ $# -gt 1 ]]; then
  echo "Usage: rpicodexauth [host]" >&2
  return 1
fi

local host="${1:-${RDEV_HOST:-rdev}}"
local remote_user="${RDEV_REMOTE_USER:-psteinroe}"
local remote_home="${RDEV_HOME:-/home/${remote_user}}"
local remote_path="${remote_home}/.local/bin:${remote_home}/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
local local_auth="${PI_AUTH_FILE:-$HOME/.pi/agent/auth.json}"
local provider="${PI_CODEX_PROVIDER:-openai-codex}"

if [[ ! -f "$local_auth" ]]; then
  echo "No local Pi auth file found: $local_auth" >&2
  return 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "rpicodexauth requires jq locally" >&2
  return 1
fi

if ! jq -e --arg provider "$provider" '.[$provider]' "$local_auth" >/dev/null; then
  echo "No $provider entry found in $local_auth" >&2
  echo "Run pi locally, then /login and choose ChatGPT Plus/Pro (Codex)." >&2
  return 1
fi

local payload
payload=$(jq -c --arg provider "$provider" '{($provider): .[$provider]}' "$local_auth") || return

local remote_cmd='set -e
if ! command -v jq >/dev/null 2>&1; then
  echo "rpicodexauth requires jq on the remote; run rebuild/bootstrap first" >&2
  exit 1
fi
umask 077
mkdir -p "$HOME/.pi/agent"
payload=$(mktemp)
trap '\''rm -f "$payload" "$HOME/.pi/agent/auth.json.tmp"'\'' EXIT
cat > "$payload"
auth="$HOME/.pi/agent/auth.json"
if [ -f "$auth" ]; then
  jq -s '\''.[0] * .[1]'\'' "$auth" "$payload" > "$auth.tmp"
else
  cp "$payload" "$auth.tmp"
fi
mv "$auth.tmp" "$auth"
chmod 600 "$auth"'

local encoded
encoded=$(printf '%s' "$remote_cmd" | base64 | tr -d '\n') || return
local runner="encoded=${(q)encoded}; cmd=\$(printf %s \"\$encoded\" | base64 -d); sudo -u ${(q)remote_user} HOME=${(q)remote_home} USER=${(q)remote_user} LOGNAME=${(q)remote_user} PATH=${(q)remote_path} ${(q)remote_home}/.nix-profile/bin/zsh -lc \"\$cmd\""

printf '%s\n' "$payload" | ssh "$host" "$runner" || return

echo "Copied $provider Pi auth to $host:${remote_user}:~/.pi/agent/auth.json"
