#!/usr/bin/env bash
set -euo pipefail

if ! git rev-parse --git-dir >/dev/null 2>&1; then
	echo "wtselect must be run inside a git repository/worktree" >&2
	exit 1
fi

selected="$({
	git worktree list --porcelain | awk '
    /^worktree / { path = substr($0, 10) }
    /^branch / {
      branch = $0
      sub(/^branch refs\/heads\//, "", branch)
      printf "%s\t%s\n", branch, path
    }
    /^detached$/ {
      printf "%s\t%s\n", "detached", path
    }
    /^bare$/ {
      printf "%s\t%s\n", "bare", path
    }
  '
} | fzf --prompt="Worktree> " --height=40% --reverse --with-nth=1,2)" || exit 130

printf '%s\n' "${selected#*$'\t'}"
